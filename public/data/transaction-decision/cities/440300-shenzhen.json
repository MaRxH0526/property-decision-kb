            "foreign_national"
          ]
        },
        "result": {
          "status": "conditional",
          "reason": "需核验境内工作或学习、居留、自用目的及当地不动产登记材料，不能套用居民家庭规则"
        },
        "effective_from": "2026-04-30",
        "effective_to": null,
        "evidence_ids": [
