      {
        "rule_id": "SZ-ELIG-OVERSEAS-ROUTE",
        "jurisdiction": "440300",
        "decision_type": "purchase_eligibility",
        "description": "境外个人及港澳台侨购房进入专门核验路径",
        "priority": 900,
        "required_inputs": [
          "buyer.residency_type"
