        "jurisdiction": "110000",
        "decision_type": "purchase_eligibility",
        "description": "京籍等同家庭五环外不限套数",
        "priority": 800,
        "required_inputs": [
          "property.zone",
          "buyer.residency_type"
        ],
        "when": {
          "all": [
            {
              "field": "property.zone",
              "op": "eq",
              "value": "outside_fifth_ring"
            },
            {
              "any": [
                {
                  "field": "buyer.residency_type",
                  "op": "eq",
                  "value": "local_hukou"
                },
                {
                  "field": "buyer.local_work_residence_permit_valid",
                  "op": "eq",
                  "value": true
                }
              ]
            }
          ]
