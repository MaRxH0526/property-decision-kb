        "effective_from": "2024-01-01",
        "effective_to": null,
        "evidence_ids": [
          "SU-EVID-ELIG-CURRENT"
        ],
        "version": "SU-ELIG-001@2024-01-01.1",
        "supersedes": [],
        "review_status": "verified"
      }
    ],
