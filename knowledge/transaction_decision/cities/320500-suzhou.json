        "jurisdiction": "320500",
        "decision_type": "purchase_eligibility",
        "description": "境内居民购买普通二手商品住房不再进行普遍限购资格审核",
        "priority": 500,
        "required_inputs": [
          "buyer.residency_type"
        ],
        "when": {
          "field": "buyer.residency_type",
          "op": "in",
          "value": [
            "local_hukou",
            "nonlocal_hukou"
